# Per-machine git overrides — NOT tracked in the dotfiles repo.
# ./setup copies this template to ~/.gitconfig.local on first run.
# Fill in identity + any OS-specific program paths below.

[user]
	name = Your Name
	email = you@example.com
	# Public half of the SSH key used for commit signing (from 1Password
	# or `cat ~/.ssh/id_ed25519.pub`). NOT a secret.
	signingkey = ssh-ed25519 AAAA...

[github]
	user = your-github-login

# Uncomment on macOS with 1Password doing SSH-based commit signing:
# [gpg "ssh"]
# 	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
#
# On Linux with 1Password:
# [gpg "ssh"]
# 	program = /opt/1Password/op-ssh-sign
