# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"

export ZSH=$HOME/.oh-my-zsh

# Starship renders the prompt — skip oh-my-zsh theme loading.
ZSH_THEME=""
CASE_SENSITIVE="true"

plugins=(git zsh-autosuggestions)

# Homebrew site-functions for completion (must be set before oh-my-zsh runs compinit)
FPATH="/opt/homebrew/share/zsh/site-functions:${FPATH}"

# Skip compinit security audit (saves ~50ms). Safe on a single-user mac.
ZSH_DISABLE_COMPFIX=true

# Skip OMZ's URL/brace auto-quoting on paste — saves a few ms.
DISABLE_MAGIC_FUNCTIONS=true

# Run zsh-autosuggestions history scan asynchronously (snappier prompt).
ZSH_AUTOSUGGEST_USE_ASYNC=1

source $ZSH/oh-my-zsh.sh

source ~/config/dotfiles/shell/env

eval "$(direnv hook zsh)"

export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh"

# Mise
eval "$(mise activate zsh)"

# fzf keybindings + completion (ctrl-R, ctrl-T, alt-C)
# stderr redirect silences a harmless `can't change option: zle` from fzf's
# option-restore loop in non-TTY contexts — keybindings still register.
source <(fzf --zsh) 2>/dev/null

# zoxide — smart cd (`z <partial-path>` jumps to frecent dirs)
eval "$(zoxide init zsh)"

# Starship
eval "$(starship init zsh)"

# Added by Antigravity
export PATH="/Users/sleistner/.antigravity/antigravity/bin:$PATH"
