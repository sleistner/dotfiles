[user]
	name = Steffen Leistner
	email = sleistner@gmail.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJsNoN1W7eaBAzhcSvrfI0wmr8MrysEGBq0fhrA4soUk

[github]
	user = sleistner

[core]
	excludesfile = /Users/sleistner/.gitignore_global
	editor = nvim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false

[init]
	defaultBranch = main

[commit]
	gpgsign = true

[gpg]
	format = ssh

[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[apply]
	whitespace = nowarn

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	autosquash = true
	autoStash = true

[rerere]
	enabled = true

[branch]
	autosetuprebase = remote
	sort = -committerdate

[column]
	ui = auto

[diff]
	algorithm = histogram
	tool = Kaleidoscope

[difftool]
	prompt = false

[difftool "Kaleidoscope"]
	cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"

[merge]
	tool = Kaleidoscope
	conflictstyle = zdiff3

[mergetool]
	keepbackup = false
	keeptemporaries = false
	trustexitcode = false
	prompt = false

[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" \"$REMOTE\"

[color]
	branch = auto
	diff = auto
	status = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[alias]
	parent = "!git show-branch | grep '*' | grep -v \"$(git rev-parse --abbrev-ref HEAD)\" | head -n1 | sed 's/.*\\[\\(.*\\)\\].*/\\1/' | sed 's/[\\^~].*//' #"
	delete-local-tags = tag -l | tag -d
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
	changelog = log --pretty=%s --first-parent
	co = checkout
	ci = commit
	st = status
	br = branch

[pretty "shortd"]
	format = "%Cred%h%Creset - %C(green) %an %C(reset) - %C(yellow)%d%Creset %s %Cgreen(%cr) %Creset"

[tig]
	line-graphics = "utf-8"
