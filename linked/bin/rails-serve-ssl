#!/usr/bin/env bash
# Start the Sparkle Rails server with SSL enabled for local development.
# (Symlinked as `rss` for convenience.)

VITE_RUBY_HTTPS=true \
  SPARKLE_PORT=3000 \
  SPARKLE_SSL=true \
  SPARKLE_AR_LOG_TO_FILE=true \
  bin/rails s \
  -b 'ssl://127.0.0.1:3000?key=config/development.key&cert=config/development.crt'
