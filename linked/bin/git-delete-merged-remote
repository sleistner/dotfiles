#!/usr/bin/env bash
# Delete remote branches that have been merged into <base-branch> (default: master).
# Usage: git-delete-merged-remote [base-branch]

base_branch=${1:-master}
exists_in_local=$(git branch --list "${base_branch}")

if [[ -z ${exists_in_local} ]]; then
    echo "Unknown base branch: ${base_branch}"
else
    git checkout --quiet "${base_branch}" &&
        git branch --remote --merged |
        grep --invert-match "${base_branch}" |
            xargs -n 1 echo |
            awk '{ sub(/origin\\//, \"\"); print }' |
            xargs -I {} git push origin :{}
fi
