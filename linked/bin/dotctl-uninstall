#!/usr/bin/env bash
# dotctl uninstall — remove packages that shipped in an earlier Brewfile but
# don't belong in the shared dotfiles (personal Mac App Store apps, unused
# formulae, stale VS Code extensions).
#
# Idempotent: safe to re-run. Skips anything that's already gone. Prompts per
# group before removing. Mac App Store apps are moved to the Trash (recoverable)
# and are prompted individually since some may be ones you still want.
#
# Usage:
#   dotctl uninstall            prompt before each item/group
#   dotctl uninstall -y         assume yes to every prompt
#   dotctl uninstall -h         this help

set -u

ASSUME_YES=0

for arg in "$@"; do
  case "$arg" in
    -h | --help)
      sed -n '2,13p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -y | --yes)
      ASSUME_YES=1
      ;;
    *)
      printf 'dotctl uninstall: unknown option: %s\n' "$arg" >&2
      exit 2
      ;;
  esac
done

# Personal Mac App Store apps that were captured in the original Brewfile.
MAS_APPS=(
  "1Password for Safari:1569813296"
  "AdBlock:1402042596"
  "Harvest:506189836"
  "Kindle:302584613"
  "Magnet:441258766"
  "MeetingBar:1532419400"
  "Microsoft Excel:462058435"
  "MindNode Classic:1289197285"
  "Numbers:409203825"
  "Slack:803453959"
  "Xcode:497799835"
)

BREW_FORMULAE=(
  contentful-cli
  pnpm
  podman
  podman-compose
  podman-tui
)

BREW_CASKS=(
  podman-desktop
)

VSCODE_EXTS=(
  lkytal.coffeelinter
)

section() { printf '\n== %s ==\n' "$1"; }
step() { printf '$ %s\n' "$1"; }

confirm() {
  local msg="$1"
  [ "$ASSUME_YES" -eq 1 ] && return 0
  if [ ! -t 0 ] && [ ! -r /dev/tty ]; then
    return 1
  fi
  printf '%s [y/N] ' "$msg"
  read -r reply </dev/tty || reply=""
  case "$reply" in [Yy]*) return 0 ;; *) return 1 ;; esac
}

# Move an app to the Trash via Finder so it's recoverable.
trash_app() {
  local app_path="$1"
  osascript -e "tell application \"Finder\" to delete POSIX file \"$app_path\"" \
    >/dev/null
}

# ---- Mac App Store apps -------------------------------------------------
section "Mac App Store apps (personal)"

installed_ids=""
if command -v mas >/dev/null 2>&1; then
  installed_ids=$(mas list 2>/dev/null | awk '{print $1}')
fi

any_mas_found=0
for entry in "${MAS_APPS[@]}"; do
  name="${entry%%:*}"
  id="${entry##*:}"
  app_path="/Applications/${name}.app"

  installed=0
  if [ -d "$app_path" ]; then
    installed=1
  elif [ -n "$installed_ids" ] && printf '%s\n' "$installed_ids" | grep -qx "$id"; then
    installed=1
  fi
  [ "$installed" -eq 1 ] || continue
  any_mas_found=1

  if confirm "Move $name to Trash?"; then
    if [ -d "$app_path" ]; then
      step "trash $app_path"
      if ! trash_app "$app_path"; then
        printf '  failed (may need Finder automation permission or admin rights).\n'
      fi
    else
      printf '  %s is in mas but not at %s — skipping.\n' "$name" "$app_path"
    fi
  else
    printf '  kept %s.\n' "$name"
  fi
done
[ "$any_mas_found" -eq 0 ] && printf '  nothing to do.\n'

# ---- Homebrew formulae --------------------------------------------------
section "Homebrew formulae"
if ! command -v brew >/dev/null 2>&1; then
  printf '  [skip] brew not installed.\n'
else
  to_remove=()
  for f in "${BREW_FORMULAE[@]}"; do
    if brew list --formula "$f" >/dev/null 2>&1; then
      to_remove+=("$f")
    fi
  done
  if [ ${#to_remove[@]} -eq 0 ]; then
    printf '  nothing to do.\n'
  elif confirm "Uninstall: ${to_remove[*]}?"; then
    step "brew uninstall ${to_remove[*]}"
    brew uninstall "${to_remove[@]}" || true
  else
    printf '  skipped.\n'
  fi
fi

# ---- Homebrew casks -----------------------------------------------------
section "Homebrew casks"
if ! command -v brew >/dev/null 2>&1; then
  printf '  [skip] brew not installed.\n'
else
  to_remove=()
  for c in "${BREW_CASKS[@]}"; do
    if brew list --cask "$c" >/dev/null 2>&1; then
      to_remove+=("$c")
    fi
  done
  if [ ${#to_remove[@]} -eq 0 ]; then
    printf '  nothing to do.\n'
  elif confirm "Uninstall casks (with --zap to remove config): ${to_remove[*]}?"; then
    step "brew uninstall --cask --zap ${to_remove[*]}"
    brew uninstall --cask --zap "${to_remove[@]}" || true
  else
    printf '  skipped.\n'
  fi
fi

# ---- VS Code extensions -------------------------------------------------
section "VS Code extensions"
if ! command -v code >/dev/null 2>&1; then
  printf '  [skip] code CLI not installed.\n'
else
  installed_exts=$(code --list-extensions 2>/dev/null || true)
  to_remove=()
  for e in "${VSCODE_EXTS[@]}"; do
    if printf '%s\n' "$installed_exts" | grep -qix "$e"; then
      to_remove+=("$e")
    fi
  done
  if [ ${#to_remove[@]} -eq 0 ]; then
    printf '  nothing to do.\n'
  elif confirm "Uninstall: ${to_remove[*]}?"; then
    for e in "${to_remove[@]}"; do
      step "code --uninstall-extension $e"
      code --uninstall-extension "$e" || true
    done
  else
    printf '  skipped.\n'
  fi
fi

echo
echo "Cleanup complete."
