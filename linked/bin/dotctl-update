#!/usr/bin/env bash
# dotctl update — bring this machine up to date with the dotfiles repo.
#
# Runs, in order:
#   1. git pull         — fast-forward the repo.
#   2. uninstall        — (opt-in) purge packages dropped from the Brewfile.
#   3. preflight        — fix conflicts / broken kegs before brew bundle.
#   4. brew bundle      — install anything in the Brewfile that's missing.
#   5. ./setup          — re-link any new entries in linked/ or xdg/.
#   6. oh-my-zsh        — install if missing (zshrc sources it).
#   7. brew upgrade     — (opt-in) upgrade outdated formulae/casks.
#
# Any failing step aborts and returns non-zero so the problem is visible.
#
# Usage:
#   dotctl update                pull + bundle + setup
#   dotctl update -c             also run `dotctl uninstall` first
#   dotctl update --clean        same as -c
#   dotctl update -u             also run `brew upgrade` at the end
#   dotctl update --upgrade      same as -u
#   dotctl update -c -u          clean first, upgrade last
#   dotctl update -h             this help

set -u

REPO="${DOTFILES_DIR:-$HOME/config/dotfiles}"
BREWFILE="$REPO/Brewfile"
RUN_UPGRADE=0
RUN_CLEAN=0

for arg in "$@"; do
  case "$arg" in
    -h | --help)
      sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -u | --upgrade)
      RUN_UPGRADE=1
      ;;
    -c | --clean)
      RUN_CLEAN=1
      ;;
    *)
      printf 'dotctl update: unknown option: %s\n' "$arg" >&2
      exit 2
      ;;
  esac
done

section() { printf '\n== %s ==\n' "$1"; }
step() { printf '$ %s\n' "$1"; }
die() {
  printf '\ndotctl update: %s — aborting.\n' "$1" >&2
  exit 1
}

# ---- 1. git pull ---------------------------------------------------------
section "git pull ($REPO)"

[ -d "$REPO/.git" ] || die "no git repo at $REPO"

if [ -n "$(git -C "$REPO" status --porcelain)" ]; then
  printf '  [skip] uncommitted changes — not pulling.\n'
  printf '         commit/stash first, or run: git -C %s status\n' "$REPO"
else
  upstream=$(git -C "$REPO" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
  if [ -z "$upstream" ]; then
    printf '  [skip] current branch has no upstream.\n'
  else
    step "git -C $REPO pull --ff-only"
    git -C "$REPO" pull --ff-only || die "git pull failed"
  fi
fi

# ---- 2. uninstall (opt-in) ----------------------------------------------
if [ "$RUN_CLEAN" -eq 1 ]; then
  section "uninstall (dropped from earlier Brewfile)"

  UNINSTALL=$(command -v dotctl-uninstall 2>/dev/null || true)
  if [ -n "$UNINSTALL" ] && [ -x "$UNINSTALL" ]; then
    step "$UNINSTALL"
    "$UNINSTALL" || printf '  uninstall returned non-zero — continuing.\n'
  else
    printf '  [skip] dotctl-uninstall not on PATH.\n'
  fi
fi

# ---- 3. preflight --------------------------------------------------------
section "preflight (conflicts + broken kegs)"

PREFLIGHT="$REPO/install/preflight-conflicts.sh"
if [ -x "$PREFLIGHT" ]; then
  step "$PREFLIGHT"
  "$PREFLIGHT" || printf '  preflight returned non-zero — continuing.\n'
else
  printf '  [skip] %s not found.\n' "$PREFLIGHT"
fi

# ---- 4. brew bundle ------------------------------------------------------
section "brew bundle"

if ! command -v brew >/dev/null 2>&1; then
  printf '  [skip] brew not installed (Linux without Linuxbrew?).\n'
else
  step "brew bundle install --file=$BREWFILE"
  brew bundle install --file="$BREWFILE" || die "brew bundle failed"
fi

# ---- 5. setup ------------------------------------------------------------
section "setup (symlinks)"

[ -x "$REPO/setup" ] || die "no executable setup script at $REPO/setup"
step "$REPO/setup"
"$REPO/setup" || die "setup failed"

# ---- 6. oh-my-zsh (bootstrap if missing) --------------------------------
# zshrc sources $ZSH/oh-my-zsh.sh — a missing install means every shell prints
# an error. Install it here so `dotctl update` self-heals the zshrc env.
section "oh-my-zsh"

if [ -d "$HOME/.oh-my-zsh" ]; then
  printf '  already installed.\n'
else
  step "install oh-my-zsh"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c \
    "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/HEAD/tools/install.sh)" \
    "" --unattended --keep-zshrc || die "oh-my-zsh install failed"

  autosugg="$HOME/.oh-my-zsh/custom/plugins/zsh-autosuggestions"
  if [ ! -d "$autosugg" ]; then
    step "clone zsh-autosuggestions"
    git clone https://github.com/zsh-users/zsh-autosuggestions "$autosugg" ||
      die "zsh-autosuggestions clone failed"
  fi
fi

# ---- 7. brew upgrade (opt-in) -------------------------------------------
if [ "$RUN_UPGRADE" -eq 1 ]; then
  section "brew upgrade"
  if ! command -v brew >/dev/null 2>&1; then
    printf '  [skip] brew not installed.\n'
  else
    step "brew upgrade"
    brew upgrade || die "brew upgrade failed"
  fi
fi

echo
echo "Update complete."
