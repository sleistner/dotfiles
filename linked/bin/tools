#!/usr/bin/env bash
# Render TOOLS.md — full, filtered, or list sections.
#
#   tools             show the full reference
#   tools SECTION     show only sections whose heading matches SECTION
#   tools -h          this help

set -e

doc="$HOME/config/dotfiles/TOOLS.md"

case "${1:-}" in
  -h | --help)
    cat <<'EOF'
usage: tools [SECTION]

  tools             show the full reference
  tools SECTION     show only sections whose heading matches SECTION
  tools -h          this help

Sections:
EOF
    awk '/^## / { sub(/^## /, "  "); print }' "$doc"
    ;;
  "")
    glow -p "$doc"
    ;;
  *)
    awk -v q="$1" '
      /^## / { section=tolower($0); printing = index(section, tolower(q)) > 0 }
      printing
    ' "$doc" | glow -p -
    ;;
esac
