#!/usr/bin/env bash
# Render TOOLS.md — full, filtered, or list sections.
#
#   dotctl tools             show the full reference
#   dotctl tools SECTION     show only sections whose heading matches SECTION
#   dotctl tools -h          this help

set -e

doc="$HOME/config/dotfiles/TOOLS.md"

case "${1:-}" in
  -h | --help)
    cat <<'EOF'
usage: dotctl tools [SECTION]

  dotctl tools             show the full reference
  dotctl tools SECTION     show only sections whose heading matches SECTION
  dotctl tools -h          this help

Sections:
EOF
    awk '/^## / { sub(/^## /, "  "); print }' "$doc"
    ;;
  "")
    mdcat -p "$doc"
    ;;
  *)
    awk -v q="$1" '
      /^## / { section=tolower($0); printing = index(section, tolower(q)) > 0 }
      printing
    ' "$doc" | mdcat -p -
    ;;
esac
