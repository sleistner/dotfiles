# vim: set syntax=bash :
#
# Shared shell env — PATH, editor, locale, ulimit, keybindings.
# Sourced from linked/zshrc on every interactive shell.

export EDITOR=nvim
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export GOPATH="$HOME/go"
export RIPGREP_CONFIG_PATH="$HOME/.config/ripgrep/ripgreprc"

# Auto-dedupe PATH entries (zsh keeps only the first occurrence).
typeset -U path PATH

PATH="/usr/local/bin:/usr/local/sbin:/usr/bin/vendor_perl:$PATH"
PATH="$PATH:$GOPATH/bin"
PATH="$HOME/.bin:$PATH"
PATH="$HOME/.local/bin:$PATH"
PATH="/opt/homebrew/opt/mysql-client/bin:$PATH"
PATH="/opt/homebrew/opt/openssl@3/bin:$PATH"
PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
PATH="$HOME/.cargo/bin:$PATH"

export PATH

ulimit -n 4095

# Oh my ZSH
bindkey '^ ' forward-word

